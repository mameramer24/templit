# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────
# Use the "pooled" connection string for the app (serverless-friendly)
DATABASE_URL="postgres://user:password@host/neondb?sslmode=require"

# ── NextAuth.js (Auth.js v5) ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="REPLACE_ME_with_openssl_rand_-base64_32"
AUTH_URL="http://localhost:3000"

# ── Vercel Blob ────────────────────────────────────────────────────────────
# Obtain from your Vercel project dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_REPLACE_ME"

# ── OAuth Providers (optional, add as needed) ─────────────────────────────
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
